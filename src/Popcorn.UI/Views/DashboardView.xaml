<UserControl x:Class="Popcorn.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">
    <ScrollViewer>
        <StackPanel Margin="30">
            <TextBlock Text="Resumo" FontSize="22" FontWeight="Bold"
                       Foreground="#1E3A5F" Margin="0,0,0,24"/>

            <WrapPanel>
                <!-- Total Eventos -->
                <Border Background="White" CornerRadius="8" Padding="24,18"
                        Margin="0,0,16,16" MinWidth="160"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalEventos}" FontSize="36" FontWeight="Bold" Foreground="#1E3A5F"/>
                        <TextBlock Text="Total de Eventos" Foreground="#7F8C8D" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Em Andamento -->
                <Border Background="White" CornerRadius="8" Padding="24,18"
                        Margin="0,0,16,16" MinWidth="160"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="{Binding EventosEmAndamento}" FontSize="36" FontWeight="Bold" Foreground="#27AE60"/>
                        <TextBlock Text="Em Andamento" Foreground="#7F8C8D" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Pendentes -->
                <Border Background="White" CornerRadius="8" Padding="24,18"
                        Margin="0,0,16,16" MinWidth="160"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="{Binding EventosPendentes}" FontSize="36" FontWeight="Bold" Foreground="#F39C12"/>
                        <TextBlock Text="Pendentes" Foreground="#7F8C8D" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Encerrados -->
                <Border Background="White" CornerRadius="8" Padding="24,18"
                        Margin="0,0,16,16" MinWidth="160"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="{Binding EventosEncerrados}" FontSize="36" FontWeight="Bold" Foreground="#95A5A6"/>
                        <TextBlock Text="Encerrados" Foreground="#7F8C8D" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Total Atletas -->
                <Border Background="White" CornerRadius="8" Padding="24,18"
                        Margin="0,0,16,16" MinWidth="160"
                        Effect="{StaticResource CardShadow}">
                    <StackPanel>
                        <TextBlock Text="{Binding TotalAtletas}" FontSize="36" FontWeight="Bold" Foreground="#3498DB"/>
                        <TextBlock Text="Atletas Cadastrados" Foreground="#7F8C8D" FontSize="13"/>
                    </StackPanel>
                </Border>
            </WrapPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
