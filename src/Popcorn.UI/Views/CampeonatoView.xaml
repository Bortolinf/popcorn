<UserControl x:Class="Popcorn.UI.Views.CampeonatoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <Button Content="+ Novo Campeonato" Command="{Binding NovoCommand}"
                    Background="#1E3A5F" Foreground="White" Padding="14,7"
                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            <TextBlock Text="{Binding Mensagem}" Foreground="#27AE60"
                       VerticalAlignment="Center" Margin="14,0,0,0" FontSize="13"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <DataGrid Grid.Column="0" ItemsSource="{Binding Campeonatos}"
                      SelectedItem="{Binding SelectedCampeonato}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Margin="0,0,16,0" GridLinesVisibility="Horizontal"
                      BorderBrush="#DDE" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome"       Binding="{Binding Nome}"                          Width="*"/>
                    <DataGridTextColumn Header="Início"     Binding="{Binding DataInicio, StringFormat=dd/MM/yyyy}" Width="100"/>
                    <DataGridTextColumn Header="Fim"        Binding="{Binding DataFim, StringFormat=dd/MM/yyyy}"    Width="100"/>
                    <DataGridTextColumn Header="Descrição"  Binding="{Binding Descricao}"                     Width="160"/>
                </DataGrid.Columns>
            </DataGrid>

            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="18"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Campeonato" FontSize="15" FontWeight="Bold"
                               Foreground="#1E3A5F" Margin="0,0,0,14"/>

                    <TextBlock Text="Nome *" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,4" Margin="0,0,0,8" BorderBrush="#BDC3C7"/>

                    <TextBlock Text="Data Início" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <DatePicker SelectedDate="{Binding DataInicio}" Margin="0,0,0,8"/>

                    <TextBlock Text="Data Fim" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <DatePicker SelectedDate="{Binding DataFim}" Margin="0,0,0,8"/>

                    <TextBlock Text="Descrição" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Descricao, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="60" Padding="5,4"
                             Margin="0,0,0,16" BorderBrush="#BDC3C7" TextWrapping="Wrap"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Salvar" Command="{Binding SalvarCommand}"
                                Background="#27AE60" Foreground="White"
                                Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                        <Button Content="Excluir" Command="{Binding ExcluirCommand}"
                                Background="#E74C3C" Foreground="White"
                                Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                        <Button Content="Cancelar" Command="{Binding CancelarCommand}"
                                Background="#95A5A6" Foreground="White"
                                Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
