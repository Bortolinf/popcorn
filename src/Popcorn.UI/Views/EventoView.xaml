<UserControl x:Class="Popcorn.UI.Views.EventoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Cabeçalho -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,16">
            <Button Content="+ Novo Evento" Command="{Binding NovoCommand}"
                    Background="#1E3A5F" Foreground="White" Padding="14,7"
                    BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            <TextBlock Text="{Binding Mensagem}" Foreground="#27AE60"
                       VerticalAlignment="Center" Margin="16,0,0,0" FontSize="13"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="420"/>
            </Grid.ColumnDefinitions>

            <!-- Lista de eventos -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Eventos}"
                      SelectedItem="{Binding SelectedEvento}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Margin="0,0,16,0" GridLinesVisibility="Horizontal"
                      BorderBrush="#DDE" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome"       Binding="{Binding Nome}"                     Width="*"/>
                    <DataGridTextColumn Header="Data"       Binding="{Binding Data, StringFormat=dd/MM/yyyy}" Width="90"/>
                    <DataGridTextColumn Header="Modalidade" Binding="{Binding Modalidade.Descricao}"     Width="120"/>
                    <DataGridTextColumn Header="Status"     Binding="{Binding Status}"                   Width="110"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Painel direito -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>

                    <!-- Seção 1: Dados básicos -->
                    <Border Background="White" CornerRadius="8" Padding="18" Margin="0,0,0,12"
                            Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Evento" FontSize="15" FontWeight="Bold"
                                       Foreground="#1E3A5F" Margin="0,0,0,14"/>

                            <TextBlock Text="Nome *" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                            <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="5,4" Margin="0,0,0,10" BorderBrush="#BDC3C7"/>

                            <TextBlock Text="Data *" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                            <DatePicker SelectedDate="{Binding Data}" Margin="0,0,0,10"/>

                            <TextBlock Text="Modalidade" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                            <ComboBox ItemsSource="{Binding Modalidades}"
                                      SelectedItem="{Binding SelectedModalidade}"
                                      DisplayMemberPath="Descricao"
                                      Margin="0,0,0,18"/>

                            <StackPanel Orientation="Horizontal">
                                <Button Content="Salvar" Command="{Binding SalvarCommand}"
                                        Background="#27AE60" Foreground="White"
                                        Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                                <Button Content="Excluir" Command="{Binding ExcluirCommand}"
                                        Background="#E74C3C" Foreground="White"
                                        Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                                <Button Content="Cancelar" Command="{Binding CancelarCommand}"
                                        Background="#95A5A6" Foreground="White"
                                        Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Seção 2: Trajetos -->
                    <Border Background="White" CornerRadius="8" Padding="18" Margin="0,0,0,12"
                            Visibility="{Binding HasSelectedEvento, Converter={StaticResource BoolToVisibility}}"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock Text="Trajetos" FontSize="14" FontWeight="Bold"
                                       Foreground="#1E3A5F" Margin="0,0,0,10"/>

                            <DataGrid ItemsSource="{Binding Trajetos}"
                                      SelectedItem="{Binding SelectedTrajeto}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      MaxHeight="180" GridLinesVisibility="Horizontal"
                                      BorderBrush="#DDE" BorderThickness="1" Margin="0,0,0,8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Nome"      Binding="{Binding Nome}"                          Width="*"/>
                                    <DataGridTextColumn Header="Dist.(km)" Binding="{Binding Distancia, StringFormat=N3}"    Width="80"/>
                                    <DataGridTextColumn Header="Largada"   Binding="{Binding HoraLargada, StringFormat=dd/MM HH:mm}" Width="100"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="+ Trajeto" Command="{Binding AddTrajetoCommand}"
                                        Background="#1E3A5F" Foreground="White"
                                        Padding="10,5" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                                <Button Content="- Remover" Command="{Binding RemoveTrajetoCommand}"
                                        Background="#E74C3C" Foreground="White"
                                        Padding="10,5" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <!-- Mini-form: adicionar trajeto -->
                            <Border Visibility="{Binding IsAddingTrajeto, Converter={StaticResource BoolToVisibility}}"
                                    Background="#F8F9FA" CornerRadius="6" Padding="12" BorderBrush="#DEE" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Novo Trajeto" FontSize="12" FontWeight="SemiBold"
                                               Foreground="#1E3A5F" Margin="0,0,0,8"/>

                                    <TextBlock Text="Nome *" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding NovoTrajetoNome, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="5,3" Margin="0,0,0,8" BorderBrush="#BDC3C7"/>

                                    <TextBlock Text="Distância (km)" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                                    <TextBox Text="{Binding NovoTrajetoDistancia, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="5,3" Margin="0,0,0,8" BorderBrush="#BDC3C7"/>

                                    <TextBlock Text="Hora de Largada" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                                    <DatePicker SelectedDate="{Binding NovoTrajetoHoraLargada}" Margin="0,0,0,10"/>

                                    <StackPanel Orientation="Horizontal">
                                        <Button Content="Confirmar" Command="{Binding ConfirmarTrajetoCommand}"
                                                Background="#27AE60" Foreground="White"
                                                Padding="10,5" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                                        <Button Content="Cancelar" Command="{Binding CancelarTrajetoCommand}"
                                                Background="#95A5A6" Foreground="White"
                                                Padding="10,5" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Seção 3: Categorias do Trajeto -->
                    <Border Background="White" CornerRadius="8" Padding="18" Margin="0,0,0,12"
                            Visibility="{Binding HasSelectedTrajeto, Converter={StaticResource BoolToVisibility}}"
                            Effect="{StaticResource CardShadow}">
                        <StackPanel>
                            <TextBlock FontSize="14" FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,0,10">
                                <Run Text="Categorias — "/>
                                <Run Text="{Binding SelectedTrajeto.Nome}"/>
                            </TextBlock>

                            <DataGrid ItemsSource="{Binding CategoriasDoTrajeto}"
                                      SelectedItem="{Binding SelectedCategoriaDoTrajeto}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      MaxHeight="160" GridLinesVisibility="Horizontal"
                                      BorderBrush="#DDE" BorderThickness="1" Margin="0,0,0,8">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Categoria"  Binding="{Binding Categoria.Descricao}" Width="*"/>
                                    <DataGridTextColumn Header="Nro Voltas" Binding="{Binding NroVoltas}"           Width="90"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                <Button Content="+ Categoria" Command="{Binding AddCategoriaCommand}"
                                        Background="#1E3A5F" Foreground="White"
                                        Padding="10,5" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                                <Button Content="- Remover" Command="{Binding RemoveCategoriaCommand}"
                                        Background="#E74C3C" Foreground="White"
                                        Padding="10,5" BorderThickness="0" Cursor="Hand"/>
                            </StackPanel>

                            <!-- Mini-form: adicionar categorias (checklist) -->
                            <Border Visibility="{Binding IsAddingCategoria, Converter={StaticResource BoolToVisibility}}"
                                    Background="#F8F9FA" CornerRadius="6" Padding="12" BorderBrush="#DEE" BorderThickness="1">
                                <StackPanel>
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="65"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="Selecione as categorias:" FontSize="12"
                                                   FontWeight="SemiBold" Foreground="#1E3A5F" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="Voltas" FontSize="10" Foreground="#777"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Visibility="{Binding PossuiVoltas, Converter={StaticResource BoolToVisibility}}"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding CategoriasSelecionaveis}" MaxHeight="220"
                                                  x:Name="ListaCategorias">
                                        <ItemsControl.Template>
                                            <ControlTemplate>
                                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                                    <ItemsPresenter/>
                                                </ScrollViewer>
                                            </ControlTemplate>
                                        </ItemsControl.Template>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Margin="0,3">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="65"/>
                                                    </Grid.ColumnDefinitions>
                                                    <CheckBox Grid.Column="0"
                                                              IsChecked="{Binding Selecionado, Mode=TwoWay}"
                                                              VerticalAlignment="Center"/>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Categoria.Descricao}"
                                                               VerticalAlignment="Center" Margin="6,0"
                                                               FontSize="12"/>
                                                    <TextBox Grid.Column="2"
                                                             Text="{Binding NroVoltas, UpdateSourceTrigger=PropertyChanged}"
                                                             Padding="4,2" BorderBrush="#BDC3C7"
                                                             VerticalAlignment="Center" ToolTip="Nro de Voltas"
                                                             Visibility="{Binding DataContext.PossuiVoltas,
                                                                          RelativeSource={RelativeSource AncestorType=ItemsControl},
                                                                          Converter={StaticResource BoolToVisibility}}"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                        <Button Content="Confirmar" Command="{Binding ConfirmarCategoriaCommand}"
                                                Background="#27AE60" Foreground="White"
                                                Padding="10,5" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                                        <Button Content="Cancelar" Command="{Binding CancelarCategoriaCommand}"
                                                Background="#95A5A6" Foreground="White"
                                                Padding="10,5" BorderThickness="0" Cursor="Hand"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Grid>
</UserControl>
