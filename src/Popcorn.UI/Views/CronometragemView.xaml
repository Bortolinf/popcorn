<UserControl x:Class="Popcorn.UI.Views.CronometragemView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <Grid Margin="16">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ═══════════════════════════════════════════
             PAINEL ESQUERDO — Controle
        ═══════════════════════════════════════════ -->
        <Border Grid.Column="0" Background="White" CornerRadius="8" Padding="18"
                Margin="0,0,12,0" Effect="{StaticResource CardShadow}">
            <StackPanel>

                <!-- Seleção de evento -->
                <TextBlock Text="Evento" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
                <ComboBox ItemsSource="{Binding Eventos}"
                          SelectedItem="{Binding EventoSelecionado}"
                          DisplayMemberPath="Nome"
                          Margin="0,0,0,14" Padding="6,5"/>

                <!-- Status -->
                <Border CornerRadius="4" Padding="8,5" Margin="0,0,0,14"
                        HorizontalAlignment="Left">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="#7F8C8D"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding StatusTexto}" Value="Pendente">
                                    <Setter Property="Background" Value="#F39C12"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusTexto}" Value="Em Andamento">
                                    <Setter Property="Background" Value="#27AE60"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding StatusTexto}" Value="Encerrado">
                                    <Setter Property="Background" Value="#95A5A6"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="{Binding StatusTexto}" Foreground="White"
                               FontWeight="Bold" FontSize="12"/>
                </Border>

                <!-- Cronômetro -->
                <Border Background="#1E3A5F" CornerRadius="8" Padding="12,16"
                        Margin="0,0,0,16">
                    <TextBlock Text="{Binding TempoDecorrido}"
                               FontFamily="Consolas" FontSize="32" FontWeight="Bold"
                               Foreground="White" HorizontalAlignment="Center"/>
                </Border>

                <!-- Largada / Encerrar -->
                <Button Content="▶  REGISTRAR LARGADA"
                        Command="{Binding IniciarLargadaCommand}"
                        Background="#27AE60" Foreground="White"
                        FontWeight="Bold" FontSize="13"
                        Padding="0,11" Margin="0,0,0,6"
                        BorderThickness="0" Cursor="Hand"/>

                <Button Content="⏹  ENCERRAR EVENTO"
                        Command="{Binding EncerrarEventoCommand}"
                        Background="#E74C3C" Foreground="White"
                        FontWeight="Bold" FontSize="13"
                        Padding="0,11" Margin="0,0,0,20"
                        BorderThickness="0" Cursor="Hand"/>

                <!-- Separador -->
                <Separator Margin="0,0,0,16"/>

                <!-- Registrar por Número -->
                <TextBlock Text="Registrar por Nº de Peito" FontSize="12"
                           FontWeight="SemiBold" Foreground="#1E3A5F" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding InputNumero, UpdateSourceTrigger=PropertyChanged}"
                             Padding="7,6" FontSize="16" FontFamily="Consolas"
                             BorderBrush="#BDC3C7"
                             KeyDown="NumeroBox_KeyDown"/>
                    <Button Grid.Column="1" Content="→"
                            Command="{Binding RegistrarPorNumeroCommand}"
                            Background="#3498DB" Foreground="White"
                            FontSize="16" Width="38" BorderThickness="0" Cursor="Hand"
                            Margin="4,0,0,0"/>
                </Grid>

                <!-- Registrar por RFID -->
                <TextBlock Text="Registrar por Tag RFID" FontSize="12"
                           FontWeight="SemiBold" Foreground="#1E3A5F" Margin="0,0,0,6"/>
                <Grid Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding InputTagRfid, UpdateSourceTrigger=PropertyChanged}"
                             Padding="7,6" FontSize="14" FontFamily="Consolas"
                             BorderBrush="#BDC3C7"
                             KeyDown="TagBox_KeyDown"/>
                    <Button Grid.Column="1" Content="→"
                            Command="{Binding RegistrarPorTagCommand}"
                            Background="#8E44AD" Foreground="White"
                            FontSize="16" Width="38" BorderThickness="0" Cursor="Hand"
                            Margin="4,0,0,0"/>
                </Grid>

                <!-- Separador -->
                <Separator Margin="0,0,0,16"/>

                <!-- Calcular Resultados -->
                <Button Content="📋  CALCULAR RESULTADOS"
                        Command="{Binding CalcularResultadosCommand}"
                        Background="#1E3A5F" Foreground="White"
                        FontWeight="Bold" FontSize="13"
                        Padding="0,11" BorderThickness="0" Cursor="Hand"
                        Margin="0,0,0,12"/>

                <!-- Mensagem -->
                <TextBlock Text="{Binding Mensagem}" TextWrapping="Wrap"
                           FontSize="12" Foreground="#2C3E50"
                           Margin="0,8,0,0"/>

            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════════
             PAINEL DIREITO — Lista de Chegadas
        ═══════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Cabeçalho -->
            <Border Grid.Row="0" Background="White" CornerRadius="8,8,0,0"
                    Padding="16,12" BorderBrush="#E0E0E0" BorderThickness="0,0,0,1"
                    Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Registro de Chegadas" FontSize="15"
                               FontWeight="Bold" Foreground="#1E3A5F"
                               VerticalAlignment="Center"/>
                    <Border Background="#3498DB" CornerRadius="10" Padding="8,2"
                            Margin="12,0,0,0" VerticalAlignment="Center">
                        <TextBlock Text="{Binding Chegadas.Count}"
                                   Foreground="White" FontSize="12" FontWeight="Bold"/>
                    </Border>
                </StackPanel>
            </Border>

            <!-- DataGrid de chegadas -->
            <DataGrid Grid.Row="1"
                      ItemsSource="{Binding Chegadas}"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserReorderColumns="False"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="1,0,1,1"
                      BorderBrush="#E0E0E0"
                      Background="White"
                      AlternatingRowBackground="#F8F9FA"
                      RowHeight="36"
                      FontSize="13">

                <DataGrid.ColumnHeaderStyle>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#F1F3F4"/>
                        <Setter Property="Foreground" Value="#555"/>
                        <Setter Property="FontWeight" Value="SemiBold"/>
                        <Setter Property="Padding" Value="10,8"/>
                        <Setter Property="BorderThickness" Value="0,0,1,0"/>
                        <Setter Property="BorderBrush" Value="#E0E0E0"/>
                    </Style>
                </DataGrid.ColumnHeaderStyle>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="Pos."        Binding="{Binding Posicao}"        Width="55"/>
                    <DataGridTextColumn Header="Atleta"      Binding="{Binding AtletaNome}"      Width="*"/>
                    <DataGridTextColumn Header="Volta"       Binding="{Binding Volta}"           Width="65"/>
                    <DataGridTextColumn Header="Horário"     Binding="{Binding HoraChegada}"     Width="130"/>
                    <DataGridTextColumn Header="Tempo"       Binding="{Binding TempoDecorrido}"  Width="130"/>
                    <DataGridTemplateColumn Header="Status"  Width="80">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <Border CornerRadius="3" Padding="6,2" HorizontalAlignment="Center"
                                        Margin="0,4">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="OK">
                                                    <Setter Property="Background" Value="#D5F5E3"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="DNS">
                                                    <Setter Property="Background" Value="#FADBD8"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="DNF">
                                                    <Setter Property="Background" Value="#FEF9E7"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="DSQ">
                                                    <Setter Property="Background" Value="#F2F3F4"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock Text="{Binding Status}" FontSize="11"
                                               FontWeight="Bold" HorizontalAlignment="Center">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding Status}" Value="OK">
                                                        <Setter Property="Foreground" Value="#1E8449"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="DNS">
                                                        <Setter Property="Foreground" Value="#C0392B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="DNF">
                                                        <Setter Property="Foreground" Value="#B7950B"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding Status}" Value="DSQ">
                                                        <Setter Property="Foreground" Value="#7F8C8D"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</UserControl>
