<UserControl x:Class="Popcorn.UI.Views.AtletaView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Barra de ações -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,12">
            <TextBox Text="{Binding Busca, UpdateSourceTrigger=PropertyChanged}"
                     Width="220" Padding="6,5" BorderBrush="#BDC3C7"
                     VerticalAlignment="Center"/>
            <Button Content="Buscar" Command="{Binding BuscarCommand}"
                    Padding="10,6" Margin="6,0,0,0" Background="#3498DB"
                    Foreground="White" BorderThickness="0" Cursor="Hand"/>
            <Button Content="+ Novo Atleta" Command="{Binding NovoCommand}"
                    Padding="14,6" Margin="10,0,0,0" Background="#1E3A5F"
                    Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand"/>
            <TextBlock Text="{Binding Mensagem}" Foreground="#27AE60"
                       VerticalAlignment="Center" Margin="14,0,0,0" FontSize="13"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- Lista -->
            <DataGrid Grid.Column="0" ItemsSource="{Binding Atletas}"
                      SelectedItem="{Binding SelectedAtleta}"
                      AutoGenerateColumns="False" IsReadOnly="True"
                      Margin="0,0,16,0" GridLinesVisibility="Horizontal"
                      BorderBrush="#DDE" BorderThickness="1">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Nome"       Binding="{Binding Nome}"            Width="*"/>
                    <DataGridTextColumn Header="Documento"  Binding="{Binding NumeroDocumento}"  Width="120"/>
                    <DataGridTextColumn Header="Sexo"       Binding="{Binding Sexo}"             Width="80"/>
                    <DataGridTextColumn Header="Equipe"     Binding="{Binding Equipe}"           Width="120"/>
                    <DataGridTextColumn Header="Cidade"     Binding="{Binding Cidade}"           Width="100"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Formulário -->
            <Border Grid.Column="1" Background="White" CornerRadius="8" Padding="18"
                    Visibility="{Binding IsEditing, Converter={StaticResource BoolToVisibility}}"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Atleta" FontSize="15" FontWeight="Bold"
                               Foreground="#1E3A5F" Margin="0,0,0,14"/>

                    <TextBlock Text="Nome *" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Nome, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,4" Margin="0,0,0,8" BorderBrush="#BDC3C7"/>

                    <TextBlock Text="Documento *" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding NumeroDocumento, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,4" Margin="0,0,0,8" BorderBrush="#BDC3C7"/>

                    <TextBlock Text="Sexo" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <ComboBox ItemsSource="{Binding SexoValues}" SelectedItem="{Binding Sexo}"
                              Margin="0,0,0,8"/>

                    <TextBlock Text="Data de Nascimento" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <DatePicker SelectedDate="{Binding DataNascimento}" Margin="0,0,0,8"/>

                    <TextBlock Text="Equipe" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Equipe, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,4" Margin="0,0,0,8" BorderBrush="#BDC3C7"/>

                    <TextBlock Text="Cidade" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Cidade, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,4" Margin="0,0,0,8" BorderBrush="#BDC3C7"/>

                    <TextBlock Text="Estado" FontSize="11" Foreground="#555" Margin="0,0,0,3"/>
                    <TextBox Text="{Binding Estado, UpdateSourceTrigger=PropertyChanged}"
                             Padding="5,4" Margin="0,0,0,16" BorderBrush="#BDC3C7"/>

                    <StackPanel Orientation="Horizontal">
                        <Button Content="Salvar" Command="{Binding SalvarCommand}"
                                Background="#27AE60" Foreground="White"
                                Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                        <Button Content="Excluir" Command="{Binding ExcluirCommand}"
                                Background="#E74C3C" Foreground="White"
                                Padding="12,6" BorderThickness="0" Cursor="Hand" Margin="0,0,6,0"/>
                        <Button Content="Cancelar" Command="{Binding CancelarCommand}"
                                Background="#95A5A6" Foreground="White"
                                Padding="12,6" BorderThickness="0" Cursor="Hand"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>
