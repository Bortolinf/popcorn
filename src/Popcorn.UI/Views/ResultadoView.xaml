<UserControl x:Class="Popcorn.UI.Views.ResultadoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#F5F6FA">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════
             LINHA 1 — Seleção de evento + ações
        ═══════════════════════════════════════ -->
        <Border Grid.Row="0" Background="White" CornerRadius="8" Padding="14,12"
                Margin="0,0,0,10" Effect="{StaticResource CardShadow}">
            <StackPanel Orientation="Horizontal">

                <TextBlock Text="Evento:" VerticalAlignment="Center"
                           FontSize="13" Foreground="#555" Margin="0,0,8,0"/>
                <ComboBox ItemsSource="{Binding Eventos}"
                          SelectedItem="{Binding EventoSelecionado}"
                          DisplayMemberPath="Nome"
                          Width="260" Padding="6,5" Margin="0,0,16,0"/>

                <Button Content="🔄  Recalcular" Command="{Binding RecalcularCommand}"
                        Background="#3498DB" Foreground="White"
                        Padding="12,6" BorderThickness="0" Cursor="Hand"
                        FontWeight="SemiBold" Margin="0,0,8,0"/>

                <Button Content="📥  Exportar CSV" Command="{Binding ExportarCsvCommand}"
                        Background="#27AE60" Foreground="White"
                        Padding="12,6" BorderThickness="0" Cursor="Hand"
                        FontWeight="SemiBold"/>

                <TextBlock Text="{Binding Mensagem}" VerticalAlignment="Center"
                           Foreground="#2C3E50" FontSize="12" Margin="16,0,0,0"
                           MaxWidth="300" TextWrapping="Wrap"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════
             LINHA 2 — Filtro Geral / Por Categoria
        ═══════════════════════════════════════ -->
        <Border Grid.Row="1" Background="White" CornerRadius="8" Padding="14,12"
                Margin="0,0,0,10" Effect="{StaticResource CardShadow}">
            <StackPanel Orientation="Horizontal">

                <RadioButton Content="Ranking Geral" IsChecked="{Binding MostrarGeral}"
                             GroupName="Modo" VerticalAlignment="Center"
                             FontSize="13" Margin="0,0,20,0"/>

                <RadioButton Content="Por Categoria" IsChecked="{Binding MostrarPorCategoria}"
                             GroupName="Modo" VerticalAlignment="Center"
                             FontSize="13" Margin="0,0,12,0"/>

                <ComboBox ItemsSource="{Binding Categorias}"
                          SelectedItem="{Binding CategoriaSelecionada}"
                          DisplayMemberPath="Descricao"
                          Width="200" Padding="6,5"
                          IsEnabled="{Binding MostrarPorCategoria}"/>
            </StackPanel>
        </Border>

        <!-- ═══════════════════════════════════════
             LINHA 3 — Cards de resumo
        ═══════════════════════════════════════ -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">

            <Border Background="White" CornerRadius="8" Padding="16,10"
                    Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding Resultados.Count}" FontSize="22"
                               FontWeight="Bold" Foreground="#1E3A5F" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="exibidos" Foreground="#7F8C8D" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="16,10"
                    Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalFinalizados}" FontSize="22"
                               FontWeight="Bold" Foreground="#27AE60" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="finalizados" Foreground="#7F8C8D" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="16,10"
                    Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalDNS}" FontSize="22"
                               FontWeight="Bold" Foreground="#E74C3C" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="DNS" Foreground="#7F8C8D" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="16,10"
                    Margin="0,0,10,0" Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalDNF}" FontSize="22"
                               FontWeight="Bold" Foreground="#F39C12" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="DNF" Foreground="#7F8C8D" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Background="White" CornerRadius="8" Padding="16,10"
                    Effect="{StaticResource CardShadow}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="{Binding TotalDSQ}" FontSize="22"
                               FontWeight="Bold" Foreground="#95A5A6" Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="DSQ" Foreground="#7F8C8D" FontSize="12"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </StackPanel>

        <!-- ═══════════════════════════════════════
             LINHA 4 — DataGrid de resultados
        ═══════════════════════════════════════ -->
        <DataGrid Grid.Row="3"
                  ItemsSource="{Binding Resultados}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  CanUserReorderColumns="False"
                  GridLinesVisibility="Horizontal"
                  BorderThickness="1"
                  BorderBrush="#E0E0E0"
                  Background="White"
                  AlternatingRowBackground="#F8F9FA"
                  RowHeight="36"
                  FontSize="13">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background"   Value="#F1F3F4"/>
                    <Setter Property="Foreground"   Value="#444"/>
                    <Setter Property="FontWeight"   Value="SemiBold"/>
                    <Setter Property="Padding"      Value="10,8"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush"  Value="#E0E0E0"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <!-- Destaque pódio -->
                        <DataTrigger Binding="{Binding Posicao}" Value="1">
                            <Setter Property="Background" Value="#FFF9E6"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Posicao}" Value="2">
                            <Setter Property="Background" Value="#F4F6F7"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Posicao}" Value="3">
                            <Setter Property="Background" Value="#FEF5EC"/>
                        </DataTrigger>
                        <!-- DNS/DNF/DSQ em cinza -->
                        <DataTrigger Binding="{Binding Status}" Value="DNS">
                            <Setter Property="Foreground" Value="#95A5A6"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="DNF">
                            <Setter Property="Foreground" Value="#95A5A6"/>
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Status}" Value="DSQ">
                            <Setter Property="Foreground" Value="#95A5A6"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>

            <DataGrid.Columns>

                <!-- Posição com medalha para top 3 -->
                <DataGridTemplateColumn Header="Pos." Width="60" SortMemberPath="Posicao">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                        VerticalAlignment="Center">
                                <TextBlock VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="{Binding Posicao}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Posicao}" Value="1">
                                                    <Setter Property="Text" Value="🥇"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Posicao}" Value="2">
                                                    <Setter Property="Text" Value="🥈"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Posicao}" Value="3">
                                                    <Setter Property="Text" Value="🥉"/>
                                                    <Setter Property="FontSize" Value="16"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

                <DataGridTextColumn Header="Atleta"      Binding="{Binding AtletaNome}"   Width="*"/>
                <DataGridTextColumn Header="Equipe"      Binding="{Binding Equipe}"       Width="140"/>
                <DataGridTextColumn Header="Categoria"   Binding="{Binding Categoria}"    Width="130"/>
                <DataGridTextColumn Header="Tempo Total" Binding="{Binding TempoTotal}"   Width="110"/>
                <DataGridTextColumn Header="T. Líquido"  Binding="{Binding TempoLiquido}" Width="110"/>
                <DataGridTextColumn Header="T. Bruto"    Binding="{Binding TempoBruto}"   Width="110"/>

                <!-- Status colorido -->
                <DataGridTemplateColumn Header="Status" Width="80">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Border CornerRadius="3" Padding="6,2"
                                    HorizontalAlignment="Center" Margin="0,4">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="#D5F5E3"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Status}" Value="DNS">
                                                <Setter Property="Background" Value="#FADBD8"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="DNF">
                                                <Setter Property="Background" Value="#FEF9E7"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding Status}" Value="DSQ">
                                                <Setter Property="Background" Value="#F2F3F4"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock Text="{Binding Status}" FontSize="11"
                                           FontWeight="Bold" HorizontalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="#1E8449"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Status}" Value="DNS">
                                                    <Setter Property="Foreground" Value="#C0392B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="DNF">
                                                    <Setter Property="Foreground" Value="#B7950B"/>
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding Status}" Value="DSQ">
                                                    <Setter Property="Foreground" Value="#7F8C8D"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>

            </DataGrid.Columns>
        </DataGrid>

    </Grid>
</UserControl>
