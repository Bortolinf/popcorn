<Window x:Class="Popcorn.UI.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Popcorn — Login" Height="420" Width="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#F5F6FA">

    <Border CornerRadius="8" Margin="30">
        <StackPanel VerticalAlignment="Center">

            <!-- Logo / Título -->
            <TextBlock Text="🍿 POPCORN" FontSize="28" FontWeight="Bold"
                       Foreground="#1E3A5F" HorizontalAlignment="Center" Margin="0,0,0,6"/>
            <TextBlock Text="Cronometragem Esportiva" FontSize="13"
                       Foreground="#7F8C8D" HorizontalAlignment="Center" Margin="0,0,0,30"/>

            <!-- Login -->
            <TextBlock Text="Usuário" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <TextBox Text="{Binding Login, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="14" Padding="8,6" Margin="0,0,0,14"
                     BorderBrush="#BDC3C7" BorderThickness="1"/>

            <!-- Senha -->
            <TextBlock Text="Senha" FontSize="12" Foreground="#555" Margin="0,0,0,4"/>
            <PasswordBox x:Name="SenhaBox" FontSize="14" Padding="8,6" Margin="0,0,0,6"
                         BorderBrush="#BDC3C7" BorderThickness="1"
                         PasswordChanged="SenhaBox_PasswordChanged"/>

            <!-- Erro -->
            <TextBlock Text="{Binding ErrorMessage}" Foreground="#E74C3C"
                       FontSize="12" Margin="0,4,0,10" TextWrapping="Wrap"/>

            <!-- Botão -->
            <Button Content="Entrar" Command="{Binding LoginCommand}"
                    FontSize="14" FontWeight="Bold" Padding="0,10"
                    Background="#1E3A5F" Foreground="White"
                    BorderThickness="0" Cursor="Hand">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}"
                                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter HorizontalAlignment="Center"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#2E4D7B"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Style>
            </Button>

        </StackPanel>
    </Border>
</Window>
